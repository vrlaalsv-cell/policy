# 이 파일을 복사해 .env 로 만들고 값을 채우세요:  cp .env.example .env
# (실제 키는 .env 에만 — .env 는 git 에 올라가지 않습니다)

ASSEMBLY_API_KEY=your_open_assembly_key
DATA_GO_KR_API_KEY=your_data_go_kr_key
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-3.5-flash-lite
CABINET_MINUTES_DIR=./data/cabinet_minutes

# 랜딩 페이지(app/assembly, app/blue-house)에서 대시보드(web/)로 이동할 때 사용하는 주소
# 로컬 개발은 기본값(http://localhost:8137) 그대로 두면 됩니다. 배포 시 실제 대시보드 URL로 변경하세요.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:8137
